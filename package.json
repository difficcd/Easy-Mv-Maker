{
    "name": "easy-mv-maker",
    "private": false,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n api,web -c green,cyan \"npm:server\" \"npm:web\"",
        "web": "vite",
        "dev:host": "vite --host",
        "server": "node server/index.js",
        "build": "vite build",
        "preview": "vite preview",
        "android:sync": "npm run build && npx cap sync android",
        "android:open": "npx cap open android",
        "android:run": "npm run build && npx cap run android"
    },
    "dependencies": {
        "@capacitor/android": "^7.0.0",
        "@capacitor/core": "^7.0.0",
        "express": "^5.2.1",
        "lucide-react": "^0.368.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@capacitor/cli": "^7.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^10.0.3",
        "vite": "^6.1.1",
        "vite-plugin-qrcode": "^0.4.1"
    }
}
